# Upstash Redis for rate limiting
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# API Keys configuration (JSON format)
# Each key has: tier (free/pro/enterprise), name (description)
API_KEYS={"ek_live_demo123":{"tier":"free","name":"Demo Key"},"ek_test_abc123":{"tier":"pro","name":"Test Pro Key"}}

# Site URL for CORS and frontend links
NEXT_PUBLIC_SITE_URL=https://validate.endpnt.dev

# Optional: Environment name for debugging
NODE_ENV=production